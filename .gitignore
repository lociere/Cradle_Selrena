# -------------------------
# 秘密/配置 文件（忽略真实配置）
# 但保留示例/模板文件以供参考
# -------------------------
# 忽略实际配置文件
configs/**/*.yaml
configs/*.yaml
configs/**/*.json
configs/*.json
configs/**/*.toml
configs/*.toml

# 允许示例/模板文件被跟踪
!configs/**/*.example.yaml
!configs/*.example.yaml
!configs/**/*.example.json
!configs/*.example.json
!configs/**/README.md
*.key
*.pem

# -------------------------
# 日志与覆盖率报告
# -------------------------
logs/*.log
*.log
coverage.xml
.coverage
.coverage.*
htmlcov/
pytestdebug.log

# -------------------------
# 测试产物（默认全部忽略，但保留占位文件）
