# -------------------------
# -------------------------
# Cradle-Selrena: repository .gitignore
# 目标：按模块组织，保留 docs/ 和 tests/，保留示例配置文件
# -------------------------

# --- Python & common ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.pyre/
.Python

# Virtual envs
.venv/
venv/
env/
ENV/

# Env files
.env
.env.*

# Build / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
pip-delete-this-directory.txt

# Node
node_modules/
.pnpm-store/
.pnpm-store
package-lock.json
pnpm-lock.yaml

# Logs and coverage
logs/
*.log
coverage.xml
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Generated / IDE
generated/
.vscode/
.idea/
.vscode/*.code-workspace
*.sublime-workspace
*.sublime-project

# Native / extensions build outputs
native-extensions/build/
native-extensions/dist/
native-extensions/**/*.pyd

# Runtime caches / local model caches
runtime/
runtime/cache/
runtime/model_cache/
temp/
cache/

# Data backups / crashes
data/backup/
data/crash/

# Assets: large model and binary files
assets/models/
*.gguf
*.safetensors
*.pt
*.pth
*.bin
assets/**/.cache/
assets/**/tmp/

# TTS / runtime artifacts
tts/

# Secrets / private configs
# 忽略实际的敏感配置，但保留示例文件供参考
configs/secret/*.yaml
configs/secret/*.json
configs/secret/*.toml
secrets.yaml
secrets.*
*.key
*.pem

# 允许跟踪示例/模板文件
!configs/secret/*.example.yaml
!configs/**/*.example.yaml
!configs/*.example.yaml
!configs/**/*.example.json
!configs/*.example.json
!configs/**/README.md

# Tests and docs: 保留在版本控制中（不要忽略）
# 保持 tests/ 和 docs/ 可见以便文档和测试被跟踪

# 保留项目级重要文件
ARCHITECTURE_OPTIMIZATION_SUMMARY.md
CONFIG_MIGRATION_COMPLETE.md
CONFIG_REFACTOR_COMPLETE.md
CONFIG_REFACTOR_SUMMARY.md
check_nonascii.py

# Misc
scripts/output/
packages/