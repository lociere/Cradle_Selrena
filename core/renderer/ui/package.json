{
  "name": "@cradle-selrena/renderer-ui",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"tsc -p tsconfig.main.json --watch\" \"cross-env VITE_DEV=1 electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "build:preload": "tsc -p tsconfig.preload.json",
    "start": "electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "ws": "^8.20.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.0.0",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}