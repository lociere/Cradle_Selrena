{
  "name": "renderer",
  "root": "core/renderer",
  "sourceRoot": "core/renderer/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @cradle-selrena/renderer run build"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @cradle-selrena/renderer run dev"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @cradle-selrena/renderer run start"
      }
    }
  }
}
