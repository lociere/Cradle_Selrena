{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cradle-selrena.local/schemas/PerceptionEvent.schema.json",
  "title": "PerceptionEvent",
  "description": "跨层感知事件契约——唯一真相源。TS 内核与 Python AI 层共用。禁止任何平台私有字段（user_id/group_id/CQ码）进入。",
  "type": "object",
  "required": ["id", "sensoryType", "source", "timestamp", "familiarity", "address_mode", "content"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "事件唯一 ID（由入站防腐层生成）"
    },
    "trace_id": {
      "type": "string",
      "description": "全链路追踪 ID（UUIDv4），从防腐网关注入，贯穿 LLM 推理、向量检索全流程"
    },
    "sensoryType": {
      "type": "string",
      "description": "感知类型：chat / voice / vision 等"
    },
    "source": {
      "type": "string",
      "description": "来源标识，等同于 scene_id。格式由 IdentityRouter 归一化（如 vessel:group:v_xxxx）"
    },
    "timestamp": {
      "type": "number",
      "description": "Unix 毫秒时间戳"
    },
    "familiarity": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10,
      "description": "对话对象熟悉度 0-10，由 Vessel Cortex 计算后注入"
    },
    "address_mode": {
      "type": "string",
      "enum": ["direct", "ambient"],
      "description": "寻址模式：direct=明确呼唤；ambient=环境感知"
    },
    "content": {
      "$ref": "#/definitions/PerceptionContent"
    }
  },
  "definitions": {
    "PerceptionContent": {
      "type": "object",
      "required": ["modality"],
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": ["string", "null"],
          "description": "注入 LLM 的完整上下文文本。内核层不应对此字段做平台特定解析"
        },
        "modality": {
          "type": "array",
          "items": { "type": "string" },
          "description": "模态列表：text / image / video"
        },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/PerceptionModalityItem" },
          "description": "结构化多模态项"
        }
      }
    },
    "PerceptionModalityItem": {
      "type": "object",
      "required": ["modality"],
      "additionalProperties": false,
      "properties": {
        "modality": {
          "type": "string",
          "enum": ["text", "image", "video"]
        },
        "text": { "type": ["string", "null"] },
        "uri": { "type": ["string", "null"] },
        "mime_type": { "type": ["string", "null"] },
        "semantic": {
          "$ref": "#/definitions/PerceptionModalitySemantic"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "PerceptionModalitySemantic": {
      "type": "object",
      "required": ["text"],
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string" },
        "source": { "type": ["string", "null"] },
        "resolved": { "type": ["boolean", "null"] },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    }
  }
}
